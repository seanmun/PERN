# Clerk — magic-link auth
# Get these from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Where Clerk sends users to sign in / where to redirect after auth
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_FALLBACK_REDIRECT_URL=/
# Webhook signing secret for lazy-claim user.created events (Phase 2.5+)
# (Clerk Dashboard → Webhooks → endpoint → "Signing Secret")
CLERK_WEBHOOK_SIGNING_SECRET=

# Neon Postgres
# Pooled connection string from https://console.neon.tech (or Vercel's Neon integration)
DATABASE_URL=

# Platform admins (godmode across all trips). Comma-separated emails, no spaces.
PLATFORM_ADMIN_EMAILS=

# Anthropic (Claude) — used by scorecard AI extraction.
ANTHROPIC_API_KEY=

# OpenAI — used to generate NBA-Jam-style arcade portraits via gpt-image-1.
OPENAI_API_KEY=

# Resend — transactional email (player invites). Dashboard: https://resend.com
# Verified sending domain is mail.buddycup.golf; from-address is below.
RESEND_API_KEY=
# Display + envelope sender for outgoing email. Must be on the verified domain.
RESEND_FROM_EMAIL=updates@mail.buddycup.golf
RESEND_FROM_NAME=BuddyCup
# Public app origin used to build invite links. No trailing slash.
# Example: https://buddycup.golf  (or the Vercel preview URL in non-prod)
NEXT_PUBLIC_APP_URL=https://buddycup.golf
